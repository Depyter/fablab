# This environment variable is used in Production and Preview environments to deploy your Convex project.
# It is not needed for local development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# Better Auth uses the current deployment URL for its own routes.
SITE_URL=http://localhost:3000

# Better Auth OAuth Proxy always routes Google OAuth through production.
BETTER_AUTH_URL=https://fablab.harleyvan.com

# This secret must be identical across production and preview/staging Convex deployments.
BETTER_AUTH_SECRET=

# Add any preview or staging origins that should be allowed to start auth flows.
# Comma-separated values are supported, including Better Auth wildcard patterns.
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,https://fablab.harleyvan.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
