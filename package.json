{
  "name": "fablab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev",
    "convex": "bunx convex dev --once",
    "predev": "convex dev --until-success && convex dashboard",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:once": "vitest run",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@convex-dev/better-auth": "^0.12.0",
    "@convex-dev/presence": "^0.3.0",
    "@convex-dev/resend": "^0.2.3",
    "@gsap/react": "^2.1.2",
    "@opennextjs/cloudflare": "^1.19.3",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-form-nextjs": "^1.29.1",
    "@types/three": "^0.184.0",
    "better-auth": "1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.36.0",
    "convex-helpers": "^0.1.115",
    "convex-test": "^0.0.50",
    "gsap": "^3.15.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.372.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-email": "^6.0.0",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.1.5"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@edge-runtime/vm": "^5.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.84.1"
  }
}
